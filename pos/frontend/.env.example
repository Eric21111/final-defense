# API Configuration
# For local development:
VITE_API_URL=http://localhost:5000

# For production (replace with your Render backend URL):
# VITE_API_URL=https://your-backend-name.onrender.com

# Receipt line width (for thermal printing)
VITE_RECEIPT_LINE_WIDTH=32

# Thermal Printer Configuration
# Set to 'true' to send receipts to thermal printer via backend API
VITE_USE_NETWORK_PRINTER=true
# Backend API base URL (for print requests)
VITE_API_BASE_URL=http://localhost:5000/api
