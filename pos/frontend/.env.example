# API Configuration
# For local development:
VITE_API_URL=http://localhost:5000

# For production (replace with your Render backend URL):
# VITE_API_URL=https://your-backend-name.onrender.com
#
# If the API is on a different host than the WebSocket upgrade (rare), set explicitly:
# VITE_WS_URL=wss://your-api-host.example.com

# Receipt line width (for thermal printing)
VITE_RECEIPT_LINE_WIDTH=32
