# API Configuration
# For local development:
VITE_API_URL=http://localhost:5000

# For production (replace with your Render backend URL):
# VITE_API_URL=https://your-backend-name.onrender.com

# Receipt line width (for thermal printing)
VITE_RECEIPT_LINE_WIDTH=32

# Thermal Printer Server URL (localhost:9100 by default)
# The frontend will send print requests directly to this URL
VITE_PRINT_SERVER_URL=http://localhost:9100
